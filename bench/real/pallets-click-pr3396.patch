From 3df4d601a5f1d1db50cbf0b33e5b0816189bc5a8 Mon Sep 17 00:00:00 2001
From: Andreas Backx <andreas@backx.org>
Date: Fri, 1 May 2026 15:32:38 +0100
Subject: [PATCH 3/3] Make pyright a bit happier.

---
 src/click/core.py   | 1 +
 src/click/parser.py | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/click/core.py b/src/click/core.py
index 776a7f5ac5..d915d92bcb 100644
--- a/src/click/core.py
+++ b/src/click/core.py
@@ -3354,6 +3354,7 @@ def consume_value(
         elif (
             self.multiple
             and value is not UNSET
+            and isinstance(value, cabc.Iterable)
             and source < ParameterSource.DEFAULT_MAP
             and any(v is FLAG_NEEDS_VALUE for v in value)
         ):
diff --git a/src/click/parser.py b/src/click/parser.py
index 1329b08f24..410d7fe106 100644
--- a/src/click/parser.py
+++ b/src/click/parser.py
@@ -83,7 +83,7 @@ def _fetch(c: deque[str]) -> str | T_UNSET:
         if nargs == 1:
             rv.append(_fetch(args))
         elif nargs > 1:
-            x = [_fetch(args) for _ in range(nargs)]
+            x: list[str | T_UNSET] = [_fetch(args) for _ in range(nargs)]
 
             # If we're reversed, we're pulling in the arguments in reverse,
             # so we need to turn them around.
