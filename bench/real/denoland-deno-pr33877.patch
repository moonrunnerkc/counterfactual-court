From c8e3e97dab2c31b950876a542664778713ffe394 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Bartek=20Iwa=C5=84czuk?= <biwanczuk@gmail.com>
Date: Wed, 6 May 2026 19:04:51 +0200
Subject: [PATCH 7/8] fix: handle format detection for hook-provided source
 correctly

When a load hook returns source without specifying format, try CJS
compilation first (with explicit "commonjs" format to prevent _compile
from falling back to loadESMFromCJS which ignores hook source). If CJS
fails with SyntaxError and ESM syntax is detected, use
loadESMFromCJSWithHookSource which compiles directly via
op_import_sync_with_source.
---
 ext/node/polyfills/01_require.js | 20 +++++++++++++++-----
 1 file changed, 15 insertions(+), 5 deletions(-)

diff --git a/ext/node/polyfills/01_require.js b/ext/node/polyfills/01_require.js
index 99efe0f17e9f74..7022a7a031007f 100644
--- a/ext/node/polyfills/01_require.js
+++ b/ext/node/polyfills/01_require.js
@@ -1647,14 +1647,24 @@ Module.prototype.load = function (filename) {
             throw err;
           }
         } else {
-          // Default: detect whether it's CJS or ESM
+          // Default: try CJS first, fall back to ESM if the source
+          // contains ESM syntax. We handle ESM fallback here (rather
+          // than in _compile) so we can use op_import_sync_with_source
+          // which bypasses the module cache for hook-provided source.
           const source = typeof result.source === "string"
             ? result.source
             : (utf8Decoder ??= new TextDecoder()).decode(result.source);
-          if (op_require_can_parse_as_esm(source)) {
-            loadESMFromCJSWithHookSource(this, this.filename, source);
-          } else {
-            this._compile(source, this.filename);
+          try {
+            this._compile(source, this.filename, "commonjs");
+          } catch (err) {
+            if (
+              err instanceof SyntaxError &&
+              op_require_can_parse_as_esm(source)
+            ) {
+              loadESMFromCJSWithHookSource(this, this.filename, source);
+            } else {
+              throw err;
+            }
           }
         }
         this.loaded = true;

