From: Edward Girling <egirling@wallstreet.io>
Date: Fri, 17 Apr 2026 15:00:14 -0700
Subject: [PATCH] Release 8.3.3

---
 CHANGES.rst    |  2 +-
 pyproject.toml |  2 +-
 uv.lock        | 28 ++++++++++++++--------------
 3 files changed, 16 insertions(+), 16 deletions(-)

diff --git a/CHANGES.rst b/CHANGES.rst
index af3a025be..d5b05c526 100644
--- a/CHANGES.rst
+++ b/CHANGES.rst
@@ -3,7 +3,7 @@
 Version 8.3.3
 -------------
 
-Unreleased
+Released 2026-04-20
 
 -   Use :func:`shlex.split` to split pager and editor commands into ``argv``
     lists for :class:`subprocess.Popen`, removing ``shell=True``.
diff --git a/pyproject.toml b/pyproject.toml
index 92e7da25e..5a0e37d04 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,6 +1,6 @@
 [project]
 name = "click"
-version = "8.3.2"
+version = "8.3.3"
 description = "Composable command line interface toolkit"
 readme = "README.md"
 license = "BSD-3-Clause"
diff --git a/uv.lock b/uv.lock
index 3fdfae85e..278506184 100644
--- a/uv.lock
+++ b/uv.lock
