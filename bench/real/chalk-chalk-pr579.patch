+	}
+
+	return 0;
+})();
+
+const colorSupport = level !== 0 && {
+	level,
 	hasBasic: true,
-	has256: false,
-	has16m: false,
-} : false;
+	has256: level >= 2,
+	has16m: level >= 3,
+};
 
 const supportsColor = {
 	stdout: colorSupport,
