{
  "name": "counterfactual-court",
  "version": "0.0.1",
  "description": "Local-first, offline-capable PR review system. Four Gemma 4 agents argue and deliberate; output is a signed, replayable .verdict bundle.",
  "type": "module",
  "license": "MIT",
  "author": "Bradley R Kinnard",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "bin": {
    "gemmacourt": "./dist/cli/gemmacourt.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/gemmacourt.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check",
    "gemmacourt": "node dist/cli/gemmacourt.js",
    "lock-runtime": "tsx scripts/lock-runtime.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.17.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "typescript": "^5.7.2",
    "zod": "^4.4.3"
  }
}
